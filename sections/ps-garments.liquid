{% comment %}
  PS Garments — scrolling showcase of garment types with generated product images.
  "Works with every product."
{% endcomment %}

<section class="ps-root ps-garments">
  <div class="ps-garments__inner">
    {%- render 'ps-section-heading',
      eyebrow: section.settings.eyebrow,
      title: section.settings.title
    -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="ps-garments__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  <div class="ps-garments__scroll" data-ps-reveal="fade">
    <div class="ps-garments__track">
      {%- for block in section.blocks -%}
        <div class="ps-garment" {{ block.shopify_attributes }}>
          <div class="ps-garment__img-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 480 | image_tag:
                loading: 'lazy',
                alt: block.settings.label,
                class: 'ps-garment__img'
              }}
            {%- elsif block.settings.asset_file != blank -%}
              <img
                src="{{ block.settings.asset_file | asset_url }}"
                alt="{{ block.settings.label }}"
                class="ps-garment__img"
                loading="lazy"
                width="320"
                height="400">
            {%- else -%}
              <div class="ps-garment__placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              </div>
            {%- endif -%}
          </div>
          <span class="ps-garment__label">{{ block.settings.label }}</span>
        </div>
      {%- endfor -%}

      {%- comment -%} Duplicate for infinite scroll effect {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="ps-garment" aria-hidden="true">
          <div class="ps-garment__img-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 480 | image_tag:
                loading: 'lazy',
                alt: block.settings.label,
                class: 'ps-garment__img'
              }}
            {%- elsif block.settings.asset_file != blank -%}
              <img
                src="{{ block.settings.asset_file | asset_url }}"
                alt="{{ block.settings.label }}"
                class="ps-garment__img"
                loading="lazy"
                width="320"
                height="400">
            {%- else -%}
              <div class="ps-garment__placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              </div>
            {%- endif -%}
          </div>
          <span class="ps-garment__label">{{ block.settings.label }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PS · Garments",
  "tag": "section",
  "class": "ps-section",
  "max_blocks": 20,
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",  "default": "Any product" },
    { "type": "text",     "id": "title",     "label": "Title",    "default": "Works with every garment." },
    { "type": "textarea", "id": "subtitle",  "label": "Subtitle", "default": "Menswear, womenswear, denim, outerwear, activewear, plus size — if it has a size chart, PrimeStyle fits it." }
  ],
  "blocks": [
    {
      "type": "garment",
      "name": "Garment",
      "settings": [
        { "type": "text",         "id": "label",      "label": "Label",       "default": "T-Shirts" },
        { "type": "image_picker", "id": "image",       "label": "Image (overrides asset)" },
        { "type": "text",         "id": "asset_file",  "label": "Asset filename" }
      ]
    }
  ],
  "presets": [{
    "name": "PS · Garments",
    "blocks": [
      { "type": "garment", "settings": { "label": "T-Shirts",    "asset_file": "ps-garment-tshirt.png" } },
      { "type": "garment", "settings": { "label": "Dresses",     "asset_file": "ps-garment-dress.png" } },
      { "type": "garment", "settings": { "label": "Suits",       "asset_file": "ps-garment-suit.png" } },
      { "type": "garment", "settings": { "label": "Tuxedos",     "asset_file": "ps-garment-tuxedo.png" } },
      { "type": "garment", "settings": { "label": "Jeans",       "asset_file": "ps-garment-jeans.png" } },
      { "type": "garment", "settings": { "label": "Blouses",     "asset_file": "ps-garment-blouse.png" } },
      { "type": "garment", "settings": { "label": "Jackets",     "asset_file": "ps-garment-jacket.png" } },
      { "type": "garment", "settings": { "label": "Coats",       "asset_file": "ps-garment-coat.png" } },
      { "type": "garment", "settings": { "label": "Activewear",  "asset_file": "ps-garment-activewear.png" } },
      { "type": "garment", "settings": { "label": "Swimwear",    "asset_file": "ps-garment-swimwear.png" } },
      { "type": "garment", "settings": { "label": "Skirts",      "asset_file": "ps-garment-skirt.png" } },
      { "type": "garment", "settings": { "label": "Formal Wear", "asset_file": "ps-garment-formal.png" } },
      { "type": "garment", "settings": { "label": "Plus Size",   "asset_file": "ps-garment-plussize.png" } },
      { "type": "garment", "settings": { "label": "Pants",       "asset_file": "ps-garment-pants.png" } },
      { "type": "garment", "settings": { "label": "Shorts",      "asset_file": "ps-garment-shorts.png" } }
    ]
  }]
}
{% endschema %}

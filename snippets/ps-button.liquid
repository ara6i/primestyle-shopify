{% comment %}
  PrimeStyle button — pill-shaped button matching prime-main landing.

  Accepts:
  - label:    Button text (required)
  - href:     URL (renders <a>); omit for <button>
  - variant:  primary | outline | tunal | white | ghost | link  (default: primary)
  - size:     sm | md | lg | xl                                  (default: md)
  - block:    Boolean — full width
  - icon:     Icon name to render (cart | arrow-right | sparkle | camera | play | check)
  - icon_position: leading | trailing                            (default: trailing)
  - type:     submit | button (when not a link)                  (default: button)
  - extra_class: extra CSS classes
  - data_attrs:  raw HTML data-* attributes string
  - aria_label:  aria-label override

  Usage:
    {% render 'ps-button', label: 'Try It On', variant: 'primary', icon: 'sparkle' %}
{% endcomment %}

{%- liquid
  assign _variant = variant | default: 'primary'
  assign _size = size | default: 'md'
  assign _icon_position = icon_position | default: 'trailing'
  assign _type = type | default: 'button'
  assign _classes = 'ps-btn ps-btn--' | append: _variant | append: ' ps-btn--' | append: _size
  if block
    assign _classes = _classes | append: ' ps-btn--block'
  endif
  if extra_class
    assign _classes = _classes | append: ' ' | append: extra_class
  endif
-%}

{%- capture _icon_svg -%}
  {%- case icon -%}
    {%- when 'arrow-right' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    {%- when 'sparkle' -%}
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.39 6.45L21 11l-6.61 2.55L12 20l-2.39-6.45L3 11l6.61-2.55z"/></svg>
    {%- when 'camera' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/></svg>
    {%- when 'cart' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
    {%- when 'play' -%}
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 4l14 8-14 8z"/></svg>
    {%- when 'check' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
  {%- endcase -%}
{%- endcapture -%}

{%- if href -%}
  <a href="{{ href }}" class="{{ _classes }}"
    {%- if aria_label %} aria-label="{{ aria_label | escape }}"{% endif -%}
    {%- if data_attrs %} {{ data_attrs }}{% endif -%}
  >
    {%- if icon != blank and _icon_position == 'leading' -%}
      <span class="ps-btn__icon">{{ _icon_svg }}</span>
    {%- endif -%}
    <span>{{ label }}</span>
    {%- if icon != blank and _icon_position == 'trailing' -%}
      <span class="ps-btn__icon">{{ _icon_svg }}</span>
    {%- endif -%}
  </a>
{%- else -%}
  <button type="{{ _type }}" class="{{ _classes }}"
    {%- if aria_label %} aria-label="{{ aria_label | escape }}"{% endif -%}
    {%- if data_attrs %} {{ data_attrs }}{% endif -%}
  >
    {%- if icon != blank and _icon_position == 'leading' -%}
      <span class="ps-btn__icon">{{ _icon_svg }}</span>
    {%- endif -%}
    <span>{{ label }}</span>
    {%- if icon != blank and _icon_position == 'trailing' -%}
      <span class="ps-btn__icon">{{ _icon_svg }}</span>
    {%- endif -%}
  </button>
{%- endif -%}

{% comment %}
  PrimeStyle media placeholder.
  Renders a labeled dashed-border block where the user will drop GIFs/images.
  If `image` is set, renders the actual image instead.

  Accepts:
  - image:    Shopify image object (optional) — if present, renders the image
  - alt:      alt text for image
  - ratio:    16-9 | 4-3 | 1-1 | 3-4 | 4-5  (default: 16-9)
  - label:    short uppercase label, e.g. "TRY-ON HERO GIF"
  - hint:     small description / file path hint
  - icon:     image | gif | video | upload | sparkle  (default: image)
  - extra_class: extra CSS classes
{% endcomment %}

{%- liquid
  assign _ratio = ratio | default: '16-9'
  assign _icon = icon | default: 'image'
  assign _classes = 'ps-placeholder ps-placeholder--ratio-' | append: _ratio
  if image
    assign _classes = _classes | append: ' ps-placeholder--filled'
  endif
  if extra_class
    assign _classes = _classes | append: ' ' | append: extra_class
  endif
-%}

<div class="{{ _classes }}">
  {%- if image -%}
    {{ image | image_url: width: 1600 | image_tag:
      loading: 'lazy',
      sizes: '100vw',
      widths: '320, 480, 640, 800, 1024, 1280, 1600',
      alt: alt
    }}
  {%- else -%}
    <div class="ps-placeholder__icon">
      {%- case _icon -%}
        {%- when 'gif' -%}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M8 9v6"/><path d="M12 9v6"/><path d="M16 9h-1.5a1.5 1.5 0 0 0-1.5 1.5v3a1.5 1.5 0 0 0 1.5 1.5H16"/></svg>
        {%- when 'video' -%}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
        {%- when 'upload' -%}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        {%- when 'sparkle' -%}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.39 6.45L21 11l-6.61 2.55L12 20l-2.39-6.45L3 11l6.61-2.55z"/></svg>
        {%- else -%}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      {%- endcase -%}
    </div>
    {%- if label -%}
      <div class="ps-placeholder__label">{{ label }}</div>
    {%- endif -%}
    {%- if hint -%}
      <div class="ps-placeholder__hint">{{ hint }}</div>
    {%- endif -%}
  {%- endif -%}
</div>
